{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "Postgres Datasource",
      "description": "Select the Postgres datasource connected to your token_usage schema",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-postgresql-datasource",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Unified AI token usage telemetry — cost burn rate, cache efficiency, and source breakdown",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Unified Cost Burn Rate Trend",
      "description": "Cost in USD per source system, hourly bucketed. Multi-select measurement_basis filters to exact/aggregate/estimated rows.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', window_start) AS time,\n  source_system,\n  SUM(cost_usd) AS \"Cost USD\"\nFROM token_usage\nWHERE window_start >= $__timeFrom()\n  AND window_start <= $__timeTo()\n  AND measurement_basis IN (${measurement_basis})\nGROUP BY 1, 2\nORDER BY 1",
          "refId": "A",
          "sql": {}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "auto",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "spanNulls": false
          },
          "unit": "currencyUSD",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["sum"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 2,
      "title": "Cache Efficiency by Source (excludes NULL cache sources)",
      "description": "Cached read tokens / input tokens * 100. Sources that do not report cached_read_tokens (e.g. Copilot) are excluded per invariant #5 — WHERE cached_read_tokens IS NOT NULL.",
      "type": "gauge",
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  source_system,\n  SUM(cached_read_tokens)::float / NULLIF(SUM(input_tokens), 0) * 100 AS efficiency\nFROM token_usage\nWHERE cached_read_tokens IS NOT NULL\n  AND window_start >= $__timeFrom()\nGROUP BY 1",
          "refId": "A",
          "sql": {}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/^efficiency$/",
          "values": true
        },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "text": {}
      }
    },
    {
      "id": 3,
      "title": "Source Usage Breakdown — Total Tokens",
      "description": "Total input + output tokens per source system for the selected time range.",
      "type": "barchart",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  source_system,\n  SUM(input_tokens + output_tokens) AS total_tokens\nFROM token_usage\nWHERE window_start >= $__timeFrom()\nGROUP BY 1\nORDER BY total_tokens DESC",
          "refId": "A",
          "sql": {}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "lineWidth": 1
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "orientation": "auto",
        "showValue": "auto",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      }
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["ai", "tokens", "telemetry", "litellm", "copilot", "cost"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Postgres Datasource",
        "multi": false,
        "name": "DS_POSTGRES",
        "options": [],
        "query": "grafana-postgresql-datasource",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "datasource": {
          "type": "grafana-postgresql-datasource",
          "uid": "${DS_POSTGRES}"
        },
        "definition": "SELECT unnest(enum_range(NULL::token_measurement_basis))::text",
        "hide": 0,
        "includeAll": true,
        "label": "Measurement Basis",
        "multi": true,
        "name": "measurement_basis",
        "options": [],
        "query": {
          "query": "SELECT unnest(enum_range(NULL::token_measurement_basis))::text",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 0,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Unified Token Telemetry",
  "uid": "unified-token-telemetry",
  "version": 1,
  "weekStart": ""
}
