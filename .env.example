# Unified Token Telemetry — Environment Variables
# Copy this file to instances/<your-name>/.env and fill in all values.
# Source it before running the worker or verification script:
#   source instances/<your-name>/.env

# ─── PostgreSQL (REQUIRED) ───────────────────
TELEMETRY_PG_HOST=localhost
TELEMETRY_PG_PORT=5432
TELEMETRY_PG_DB=your_database
TELEMETRY_PG_USER=your_user
TELEMETRY_PG_PASSWORD=your_password
TELEMETRY_PG_SCHEMA=telemetry

# ─── LiteLLM / Prometheus (if sources.litellm.enabled) ───
LITELLM_PROMETHEUS_URL=http://your-prometheus:9090

# ─── GitHub Copilot (if sources.copilot.enabled) ─────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=your-org-name

# ─── OpenAI Organization API (if sources.openai.enabled) ─
# Requires org-level admin key. Get from: https://platform.openai.com/settings/organization/api-keys
OPENAI_ADMIN_KEY=sk-org-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_ORG_ID=org-xxxxxxxxxxxxxxxxxxxx

# ─── Anthropic Admin API (if sources.anthropic.enabled) ───
# Requires admin API key (sk-ant-admin-...). Get from: https://console.anthropic.com/settings/admin-keys
ANTHROPIC_ADMIN_KEY=sk-ant-admin-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Grafana (if consumers.grafana.enabled) ──────────────
GRAFANA_URL=http://your-grafana:3000
GRAFANA_API_KEY=glsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
